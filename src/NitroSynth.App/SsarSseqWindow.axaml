<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NitroSynth.App.SsarSseqWindow"
        x:CompileBindings="False"
        Width="1000"
        Height="560"
        MinWidth="1000"
        MinHeight="560"
        Title="SSAR Sequence">

  <Window.Styles>
    <StyleInclude Source="avares://NitroSynth.App/InstrumentEditor/EditorTheme.axaml"/>

    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="TextBlock.sseqLabel">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <Style Selector="ComboBox.metaMid">
      <Setter Property="Width" Value="174"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="8,0,28,0"/>
    </Style>

    <Style Selector="TextBox.metaMid">
      <Setter Property="Width" Value="174"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="8,0,0,0"/>
      <Setter Property="IsReadOnly" Value="True"/>
    </Style>

    <Style Selector="TextBox.metaValue">
      <Setter Property="Width" Value="56"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="IsReadOnly" Value="True"/>
    </Style>

    <Style Selector="Button.sseqAction">
      <Setter Property="Width" Value="72"/>
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinHeight" Value="24"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBox.sseqEditor">
      <Setter Property="Height" Value="360"/>
      <Setter Property="MinHeight" Value="300"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="VerticalContentAlignment" Value="Top"/>
      <Setter Property="Padding" Value="6,4,6,4"/>
    </Style>
  </Window.Styles>

  <Border Classes="editorRoot">
    <Grid RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="8">
      <Grid Grid.Row="0"
            ColumnDefinitions="Auto,8,Auto,8,Auto,8,Auto,8,Auto,*"
            RowDefinitions="Auto">
        <StackPanel Grid.Column="0" Spacing="0" VerticalAlignment="Top">
          <TextBlock Classes="sseqLabel" Text="SBNK"/>
          <ComboBox x:Name="SbnkComboBox"
                    Classes="metaMid"
                    SelectionChanged="OnSbnkSelectionChanged"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="0" VerticalAlignment="Top">
          <TextBlock Classes="sseqLabel" Text="Volume"/>
          <TextBox x:Name="VolumeTextBox" Classes="metaValue"/>
        </StackPanel>

        <StackPanel Grid.Column="4" Spacing="0" VerticalAlignment="Top">
          <TextBlock Classes="sseqLabel" Text="Channel Priority"/>
          <TextBox x:Name="ChannelPriorityTextBox" Classes="metaValue"/>
        </StackPanel>

        <StackPanel Grid.Column="6" Spacing="0" VerticalAlignment="Top">
          <TextBlock Classes="sseqLabel" Text="Player Priority"/>
          <TextBox x:Name="PlayerPriorityTextBox" Classes="metaValue"/>
        </StackPanel>

        <StackPanel Grid.Column="8" Spacing="0" VerticalAlignment="Top">
          <TextBlock Classes="sseqLabel" Text="Player"/>
          <TextBox x:Name="PlayerTextBox" Classes="metaMid"/>
        </StackPanel>
      </Grid>

      <Separator Grid.Row="1"/>

      <TextBox Grid.Row="2"
                x:Name="DecompilerTextBox"
                Classes="sseqEditor"
                AcceptsReturn="True"
                TextWrapping="NoWrap"
                IsUndoEnabled="True"
                IsReadOnly="False"
               VerticalContentAlignment="Top"
               HorizontalContentAlignment="Left"
               FontFamily="Consolas"
               FontSize="11"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

      <Grid Grid.Row="3"
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="8">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button x:Name="PlayButton"
                  Classes="sseqAction"
                  Content="PLAY"
                  Click="OnPlayClicked"/>
          <Button x:Name="PauseButton"
                  Classes="sseqAction"
                  Content="PAUSE"
                  Click="OnPauseClicked"/>
          <Button x:Name="StopButton"
                  Classes="sseqAction"
                  Content="STOP"
                  Click="OnStopClicked"/>
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Column="1"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right">
          <Button Classes="sseqAction"
                  Content="SAVE"
                  Click="OnSaveClicked"/>
          <Button Classes="sseqAction"
                  Content="HEX"
                  Click="OnHexClicked"/>
          <Button Classes="sseqAction"
                  Content="REPLACE"
                  Click="OnReplaceClicked"/>
          <Button Classes="sseqAction"
                  Content="EXPORT"
                  Click="OnExportClicked"/>
          <Button Classes="sseqAction"
                  Content="CLOSE"
                  Click="OnCloseClicked"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>

